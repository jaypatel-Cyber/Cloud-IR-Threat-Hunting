# ── AWS Credentials ────────────────────────────
# Use a read-only IAM role for CloudTrail analysis
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1

# ── CloudTrail S3 Source ───────────────────────
CLOUDTRAIL_S3_BUCKET=your-cloudtrail-logs-bucket
CLOUDTRAIL_S3_PREFIX=AWSLogs/123456789012/CloudTrail/

# ── LocalStack (local AWS simulation) ─────────
# Set this to use LocalStack instead of real AWS
AWS_ENDPOINT_URL=http://localhost:4566
LOCALSTACK_REGION=us-east-1

# ── Hunt Output ───────────────────────────────
REPORT_DIR=reports

# ── Anomaly Detection Thresholds (optional) ───
ZSCORE_THRESHOLD=2.5
IQR_MULTIPLIER=1.5
RARE_API_THRESHOLD=0.02
CREATION_BURST_THRESHOLD=3
